# Google Gemini API Configuration
# Required for chat functionality
GEMINI_API_KEY=your_gemini_api_key_here

# Vapi Configuration  
# Required for phone call functionality
VAPI_API_KEY=your_vapi_api_key_here
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
VAPI_CALL_PHONE_NUMBER_ID=your_vapi_call_phone_number_id_here
VAPI_SMS_IMPORT_ID=your_vapi_twilio_import_id_here

# Twilio Configuration
# Required for SMS functionality
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# SMTP Email Configuration
# Required for sending email from your company email address
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_company_email@example.com
SMTP_PASS=your_email_app_password
SMTP_FROM=Kyron Medical <your_company_email@example.com>

# Server Configuration
PORT=5000
